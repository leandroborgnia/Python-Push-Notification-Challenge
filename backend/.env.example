# Copy to .env for local host runs (docker compose sets these per-service).
DATABASE_URL_ASYNC=postgresql+asyncpg://app:app@localhost:5432/app
DATABASE_URL_SYNC=postgresql+psycopg://app:app@localhost:5432/app
BROKER_URL=amqp://guest:guest@localhost:5672//

OTEL_SERVICE_NAME=notification-service
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
# SENTRY_DSN=
ENVIRONMENT=dev

READINESS_CHECK_TIMEOUT_S=2.0
READINESS_NORMAL_BUDGET_S=1.0
SMOKE_TIMEOUT_S=10.0
