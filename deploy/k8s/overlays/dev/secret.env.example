# Template for the dev `notification-secrets` Secret (Principle VI; finding C1).
# up-dev copies this to the gitignored `secret.env` on first run, which the kustomize
# secretGenerator reads. These are PLACEHOLDER non-production values for the ephemeral
# in-cluster dev datastores — never put real credentials here, and never commit secret.env.
#
# Service-DNS hosts (postgres / rabbitmq / mailpit / provider-sim) resolve inside the
# `notification` namespace.
database-url-async=postgresql+asyncpg://app:app@postgres:5432/app
database-url-sync=postgresql+psycopg://app:app@postgres:5432/app
broker-url=amqp://guest:guest@rabbitmq:5672//

# 003 auth + channels. `jwt-secret` is a DEV placeholder; the app refuses it when environment!=dev
# (Principle VI). Auth mail goes to the in-cluster Mailpit catcher (SMTP 1025).
environment=dev
jwt-secret=dev-insecure-placeholder-not-for-prod
smtp-host=mailpit
smtp-port=1025
mail-from=no-reply@notification.local
# The simulated provider Service (port 80) and the API webhook the worker tells it to call back.
provider-base-url=http://provider-sim
webhook-callback-url=http://notification-api/api/v1/webhooks/delivery
