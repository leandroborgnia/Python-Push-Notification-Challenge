{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "backend: uv sync",
      "type": "shell",
      "command": "uv sync",
      "options": { "cwd": "${workspaceFolder}/backend" },
      "problemMatcher": []
    },
    {
      "label": "backend: ruff fix",
      "type": "shell",
      "command": "uv run ruff check --fix .",
      "options": { "cwd": "${workspaceFolder}/backend" },
      "problemMatcher": []
    },
    {
      "label": "backend: ruff format",
      "type": "shell",
      "command": "uv run ruff format .",
      "options": { "cwd": "${workspaceFolder}/backend" },
      "problemMatcher": []
    },
    {
      "label": "backend: lint + format",
      "dependsOrder": "sequence",
      "dependsOn": ["backend: ruff fix", "backend: ruff format"],
      "problemMatcher": []
    },
    {
      "label": "backend: mypy",
      "type": "shell",
      "command": "uv run mypy",
      "options": { "cwd": "${workspaceFolder}/backend" },
      "problemMatcher": []
    },
    {
      "label": "backend: pytest",
      "type": "shell",
      "command": "uv run pytest",
      "options": { "cwd": "${workspaceFolder}/backend" },
      "group": "test",
      "problemMatcher": []
    },
    {
      "label": "backend: alembic upgrade head",
      "type": "shell",
      "command": "uv run alembic upgrade head",
      "options": { "cwd": "${workspaceFolder}/backend" },
      "problemMatcher": []
    },
    {
      "label": "stack: docker compose up",
      "type": "shell",
      "command": "docker compose up",
      "options": { "cwd": "${workspaceFolder}" },
      "problemMatcher": []
    },
    {
      "label": "frontend: dev",
      "type": "shell",
      "command": "npm run dev",
      "options": { "cwd": "${workspaceFolder}/frontend" },
      "problemMatcher": []
    },
    {
      "label": "frontend: build",
      "type": "shell",
      "command": "npm run build",
      "options": { "cwd": "${workspaceFolder}/frontend" },
      "problemMatcher": []
    },
    {
      "label": "frontend: test",
      "type": "shell",
      "command": "npm test",
      "options": { "cwd": "${workspaceFolder}/frontend" },
      "group": "test",
      "problemMatcher": []
    }
  ]
}
